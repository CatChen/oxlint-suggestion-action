{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "arrowParens": "always",
  "bracketSpacing": true,
  "bracketSameLine": false,
  "semi": true,
  "singleQuote": true,
  "tabWidth": 2,
  "trailingComma": "all",
  "importOrder": [
    "^@action/core/(.*)$",
    "^@action/github/(.*)$",
    "^@action/exec/(.*)$",
    "^@action/glob/(.*)$",
    "^@action/(.*)$",
    "<THIRD_PARTY_MODULES>",
    "^[./]"
  ],
  "importOrderSortIndividualImports": true,
  "importOrderMergeDuplicateImports": true,
  "importOrderBuiltinModulesToTop": true,
  "importOrderTypeImportsToTop": true,
  "printWidth": 80,
  "ignorePatterns": ["dist/", "bundle/"],
  "sortImports": {}
}
