{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "arrowParens": "always",
  "bracketSpacing": true,
  "bracketSameLine": false,
  "semi": true,
  "singleQuote": true,
  "tabWidth": 2,
  "trailingComma": "all",
  "printWidth": 80,
  "sortPackageJson": false,
  "ignorePatterns": ["dist/", "bundle/"],
  "sortImports": {
    "customGroups": [
      {
        "groupName": "actions",
        "selector": "external",
        "elementNamePattern": ["@actions/**"]
      }
    ],
    "groups": [
      "builtin",
      "type",
      "actions",
      "external",
      ["internal", "subpath"],
      ["parent", "sibling", "index"],
      "style",
      "unknown"
    ]
  }
}
